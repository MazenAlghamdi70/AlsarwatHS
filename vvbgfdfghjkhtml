    <!-- Document Viewer Modal -->
    <div id="documentModal" class="document-modal">
        <div class="document-viewer">
            <button class="close-doc-btn" onclick="closeDocumentViewer()">✕ إغلاق</button>
            <div id="documentContent" style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;"></div>
        </div>
    </div>

    <!-- Edit Student Modal -->
    <div id="editModal" class="modal">
        <div class="modal-content password-modal">
            <button class="close-btn" onclick="closeEditModal()">×</button>
            <h2 style="margin-bottom: 20px;">تعديل بيانات الطالب</h2>
            <form id="editForm">
                <input type="hidden" id="editIndex">
                <div class="form-group">
                    <label>اسم الطالب:</label>
                    <input type="text" id="editName" required>

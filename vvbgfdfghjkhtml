                    <label>رقم جوال الطالب:</label>
                    <input type="tel" id="editPhone" required pattern="05[0-9]{8}" maxlength="10">
                </div>
                <div class="form-group">
                    <label>رقم جوال ولي الأمر:</label>
                    <input type="tel" id="editGuardianPhone" required pattern="05[0-9]{8}" maxlength="10">
                </div>

                    <label>الدرجة:</label>
                    <input type="number" id="editGrade" required min="0" max="100" step="0.01">
                </div>
                <div class="form-group">
                    <label>الحالة:</label>
                    <select id="editStatus" required>
                        <option value="pending">قيد المراجعة</option>
                        <option value="accepted">مقبول</option>
                        <option value="rejected">مرفوض</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>الملاحظات:</label>
                    <textarea id="editNotes"></textarea>
                </div>
                <button type="submit" class="submit-btn">حفظ التعديلات</button>
            </form>
        </div>
    </div>

    <script>
        const ADMIN_CODE = 'SARW@2672';
        let students = [];
        let middleSchools = ['التوفيق', 'محضرة', 'الملك سعود', 'أخرى'];
        let currentTab = 'students';

        // Load data on page load
        window.addEventListener('load', function() {
            const sessionData = window.name;
            if (sessionData) {
                try {
                    const parsed = JSON.parse(sessionData);
                    if (parsed.students) {
                        students = parsed.students;
                    }
                    if (parsed.middleSchools) {
                        middleSchools = parsed.middleSchools;
                    }
                } catch(e) {}
            }
            updateSchoolDropdown();
        });

        // Save to session
        function saveToSession() {
            const data = { 
                students: students,
                middleSchools: middleSchools 
            };
            window.name = JSON.stringify(data);
        }

        // Update school dropdown
        function updateSchoolDropdown() {
            const select = document.getElementById('middleSchool');
            select.innerHTML = '<option value="">اختر المدرسة...</option>';
            
            middleSchools.forEach(school => {
                const option = document.createElement('option');
                option.value = school;
                option.textContent = school;
                select.appendChild(option);
            });
        }

        // Handle school selection
        function handleSchoolSelection() {
            const select = document.getElementById('middleSchool');
            const otherGroup = document.getElementById('otherSchoolGroup');
            const otherInput = document.getElementById('otherSchool');
            
            if (select.value === 'أخرى') {
                otherGroup.style.display = 'block';
                otherInput.required = true;
            } else {
                otherGroup.style.display = 'none';
                otherInput.required = false;
                otherInput.value = '';
            }
        }

        // Preview uploaded images
        document.getElementById('documents').addEventListener('change', function(e) {
            const files = e.target.files;
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            
            for (let file of files) {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = document.createElement('img');
                        img.src = event.target.result;
                        img.className = 'preview-img';
                        img.alt = file.name;
                        preview.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                } else if (file.type === 'application/pdf') {
                    const p = document.createElement('p');
                    p.style.color = 'var(--primary)';
                    p.style.fontWeight = 'bold';
                    p.innerHTML = `📄 ${file.name}`;
                    preview.appendChild(p);
                }
            }
        });

        // Preview additional files
        document.getElementById('additionalFiles').addEventListener('change', function(e) {
            const files = e.target.files;
            const preview = document.getElementById('additionalPreview');
            preview.innerHTML = '';
            
            for (let file of files) {
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(event) {
                        const img = document.createElement('img');
                        img.src = event.target.result;
                        img.className = 'preview-img';
                        img.alt = file.name;
                        preview.appendChild(img);
                    }
                    reader.readAsDataURL(file);
                } else if (file.type === 'application/pdf') {
                    const p = document.createElement('p');
                    p.style.color = 'var(--success)';
                    p.style.fontWeight = 'bold';
                    p.innerHTML = `📄 ${file.name}`;
                    preview.appendChild(p);
                }
            }
        });

        // Handle form submission
        document.getElementById('registrationForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const studentId = document.getElementById('studentId').value;
            const studentName = document.getElementById('studentName').value;
            const phoneNumber = document.getElementById('phoneNumber').value;
            const guardianPhone = document.getElementById('guardianPhone').value;
            const middleSchool = document.getElementById('middleSchool').value;
            const grade = parseFloat(document.getElementById('grade').value);
            const documentFiles = document.getElementById('documents').files;
            const additionalFiles = document.getElementById('additionalFiles').files;

            if (students.find(s => s.id === studentId)) {
                showMessage('الطالب مسجل مسبقاً!', 'error');
                return;
            }

            if (!/^05[0-9]{8}$/.test(phoneNumber)) {
                showMessage('رقم جوال الطالب يجب أن يبدأ بـ 05 ويحتوي على 10 أرقام', 'error');
                return;
            }

            if (!/^05[0-9]{8}$/.test(guardianPhone)) {
                showMessage('رقم جوال ولي الأمر يجب أن يبدأ بـ 05 ويحتوي على 10 أرقام', 'error');
                return;
            }

            if (grade < 0 || grade > 100) {
                showMessage('الدرجة يجب أن تكون بين 0 و 100', 'error');
                return;
            }

            // Combine all files
            const allFiles = [...documentFiles, ...additionalFiles];
            
            // Read all files
            let filesRead = 0;
            const documentsData = [];
            const additionalData = [];
            
            if (allFiles.length === 0) {
                showMessage('يجب إرفاق الشهادة على الأقل', 'error');
                return;
            }
            
            for (let i = 0; i < allFiles.length; i++) {
                const file = allFiles[i];
                const isAdditional = i >= documentFiles.length;
                
                const reader = new FileReader();
                reader.onload = function(e) {
                    const fileData = {
                        name: file.name,
                        type: file.type,
                        data: e.target.result
                    };
                    
                    if (isAdditional) {
                        additionalData.push(fileData);
                    } else {
                        documentsData.push(fileData);
                    }
                    
                    filesRead++;
                    if (filesRead === allFiles.length) {
                        const student = {
                            id: studentId,
                            name: studentName,
                            phone: phoneNumber,
                            guardianPhone: guardianPhone,
                            middleSchool: middleSchool,
                            grade: grade,
                            documents: documentsData,
                            additionalFiles: additionalData,
                            status: 'pending',
                            notes: '',
                            timestamp: new Date().toLocaleString('ar-SA')
                        };

                        // إرسال البيانات إلى Google Sheets
                        sendToGoogleSheets(student).then(function(response) {
                            students.push(student);
                            saveToSession();
                            
                            showMessage('تم تسجيل الطالب بنجاح وإرسال البيانات إلى Google Sheets! ✓', 'success');
                            
                            document.getElementById('registrationForm').reset();
                            document.getElementById('imagePreview').innerHTML = '';
                            document.getElementById('additionalPreview').innerHTML = '';
                        }).catch(function(error) {
                            // حتى لو فشل الإرسال، احفظ البيانات محلياً
                            students.push(student);
                            saveToSession();
                            
                            showMessage('تم تسجيل الطالب محلياً، لكن فشل الإرسال إلى Google Sheets. تحقق من الاتصال بالإنترنت.', 'error');
                            console.error('خطأ في الإرسال:', error);
                            
                            document.getElementById('registrationForm').reset();
                            document.getElementById('imagePreview').innerHTML = '';
                            document.getElementById('additionalPreview').innerHTML = '';
                        });
                    }
                };
                reader.readAsDataURL(file);
            }
        });

        // دالة إرسال البيانات إلى Google Sheets
        function sendToGoogleSheets(student) {
            return fetch(GOOGLE_SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(student)
            });
        }

        function showMessage(msg, type) {
            const messageDiv = document.getElementById('message');
            messageDiv.className = 'message ' + type;
            messageDiv.textContent = msg;
            messageDiv.style.display = 'block';
            
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 4000);
        }

        // Password Modal
        function showPasswordModal() {
            document.getElementById('passwordModal').style.display = 'flex';
            document.getElementById('adminPassword').value = '';
            document.getElementById('adminPassword').focus();
        }

        function closePasswordModal() {
            document.getElementById('passwordModal').style.display = 'none';
        }

        function checkPassword() {
            const password = document.getElementById('adminPassword').value;
            
            if (password === ADMIN_CODE) {
                closePasswordModal();
                showAdminPanel();
            } else {
                alert('كود خاطئ! حاول مرة أخرى');
                document.getElementById('adminPassword').value = '';
            }
        }

        document.getElementById('adminPassword').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                checkPassword();
            }
        });

        // Admin Panel
        function showAdminPanel() {
            updateStats();
            updateStudentsList();
            updateSchoolsList();
            updateFilters();
            document.getElementById('adminModal').style.display = 'flex';
        }

        function closeAdminModal() {
            document.getElementById('adminModal').style.display = 'none';
        }

        function switchTab(tab) {
            currentTab = tab;
            
            // Update tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            // Update tab content
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(tab + 'Tab').classList.add('active');
            
            if (tab === 'stats') {
                updateStats();
                updateCharts();
            } else if (tab === 'schools') {
                updateSchoolsList();
            }
        }

        // Statistics
        function updateStats() {
            if (students.length === 0) {
                document.getElementById('totalStudents').textContent = '0';
                document.getElementById('avgGrade').textContent = '0';
                document.getElementById('maxGrade').textContent = '0';
                document.getElementById('minGrade').textContent = '0';
                document.getElementById('acceptedCount').textContent = '0';
                document.getElementById('pendingCount').textContent = '0';
                return;
            }

            const grades = students.map(s => s.grade);
            const avgGrade = (grades.reduce((a, b) => a + b, 0) / grades.length).toFixed(2);
            const maxGrade = Math.max(...grades);
            const minGrade = Math.min(...grades);
            const acceptedCount = students.filter(s => s.status === 'accepted').length;
            const pendingCount = students.filter(s => s.status === 'pending').length;

            document.getElementById('totalStudents').textContent = students.length;
            document.getElementById('avgGrade').textContent = avgGrade;
            document.getElementById('maxGrade').textContent = maxGrade;
            document.getElementById('minGrade').textContent = minGrade;
            document.getElementById('acceptedCount').textContent = acceptedCount;
            document.getElementById('pendingCount').textContent = pendingCount;
        }

        function updateCharts() {
            // Schools Chart
            const schoolCounts = {};
            students.forEach(s => {
                schoolCounts[s.middleSchool] = (schoolCounts[s.middleSchool] || 0) + 1;
            });

            const schoolsChart = document.getElementById('schoolsChart');
            schoolsChart.innerHTML = '';
            
            const maxCount = Math.max(...Object.values(schoolCounts));
            
            for (let school in schoolCounts) {
                const count = schoolCounts[school];
                const percentage = (count / students.length * 100).toFixed(1);
                const width = (count / maxCount * 100).toFixed(1);
                
                const bar = document.createElement('div');
                bar.className = 'bar';
                bar.innerHTML = `
                    <div class="bar-label">${school}</div>
                    <div class="bar-content">
                        <div class="bar-fill" style="width: ${width}%">${count} طالب (${percentage}%)</div>
                    </div>
                `;
                schoolsChart.appendChild(bar);
            }

            // Grades Chart
            const grade90 = students.filter(s => s.grade >= 90 && s.grade <= 100).length;
            const grade80 = students.filter(s => s.grade >= 80 && s.grade < 90).length;
            const grade70 = students.filter(s => s.grade >= 70 && s.grade < 80).length;
            const grade60 = students.filter(s => s.grade < 70).length;

            const maxGradeCount = Math.max(grade90, grade80, grade70, grade60);

            document.getElementById('grade90').style.width = (grade90 / maxGradeCount * 100) + '%';
            document.getElementById('grade90').textContent = grade90 + ' طالب';
            
            document.getElementById('grade80').style.width = (grade80 / maxGradeCount * 100) + '%';
            document.getElementById('grade80').textContent = grade80 + ' طالب';
            
            document.getElementById('grade70').style.width = (grade70 / maxGradeCount * 100) + '%';
            document.getElementById('grade70').textContent = grade70 + ' طالب';
            
            document.getElementById('grade60').style.width = (grade60 / maxGradeCount * 100) + '%';
            document.getElementById('grade60').textContent = grade60 + ' طالب';
        }

        // Students List
        function updateStudentsList() {
            filterStudents();
        }

        function updateFilters() {
            // Update school filter
            const schoolFilter = document.getElementById('schoolFilter');
            schoolFilter.innerHTML = '<option value="">جميع المدارس</option>';
            
            const uniqueSchools = [...new Set(students.map(s => s.middleSchool))];
            uniqueSchools.forEach(school => {
                const option = document.createElement('option');
                option.value = school;
                option.textContent = school;
                schoolFilter.appendChild(option);
            });
        }

        function filterStudents() {
            const searchText = document.getElementById('searchInput').value.toLowerCase();
            const schoolFilter = document.getElementById('schoolFilter').value;
            const statusFilter = document.getElementById('statusFilter').value;
            const sortBy = document.getElementById('sortBy').value;

            let filtered = students.filter(s => {
                const matchSearch = s.name.toLowerCase().includes(searchText) || 
                                   s.id.includes(searchText);
                const matchSchool = !schoolFilter || s.middleSchool === schoolFilter;
                const matchStatus = !statusFilter || s.status === statusFilter;
                
                return matchSearch && matchSchool && matchStatus;
            });

            // Sort
            if (sortBy === 'grade') {
                filtered.sort((a, b) => b.grade - a.grade);
            } else if (sortBy === 'name') {
                filtered.sort((a, b) => a.name.localeCompare(b.name, 'ar'));
            } else if (sortBy === 'date') {
                filtered.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
            }

            displayStudents(filtered);
        }

        function displayStudents(studentsList) {
            const tbody = document.getElementById('studentsBody');
            tbody.innerHTML = '';

            if (studentsList.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" style="padding: 30px; color: #999;">لا توجد نتائج</td></tr>';
                return;
            }

            studentsList.forEach((student, index) => {
                const row = tbody.insertRow();
                const originalIndex = students.indexOf(student);
                
                const statusClass = `status-${student.status}`;
                const statusText = {
                    'pending': 'قيد المراجعة',
                    'accepted': 'مقبول',
                    'rejected': 'مرفوض'
                }[student.status];

                row.innerHTML = `
                    <td class="rank">#${index + 1}</td>
                    <td>${student.id}</td>
                    <td>${student.name}</td>
                    <td>${student.phone}</td>
                    <td>${student.guardianPhone || '-'}</td>
                    <td>${student.middleSchool}</td>
                    <td><strong>${student.grade}</strong></td>
                    <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                    <td style="max-width: 150px; overflow: hidden; text-overflow: ellipsis;">${student.notes || '-'}</td>
                    <td>
                        <button class="action-btn view-doc-btn" onclick="viewDocuments(${originalIndex})" title="عرض المستندات">👁️</button>
                        <button class="action-btn edit-btn" onclick="editStudent(${originalIndex})" title="تعديل">✏️</button>
                        <button class="action-btn delete-student-btn" onclick="deleteStudent(${originalIndex})" title="حذف">🗑️</button>
                    </td>
                `;
            });
        }

        function viewDocuments(index) {
            const student = students[index];
            const documentContent = document.getElementById('documentContent');
            documentContent.innerHTML = '';

            student.documents.forEach(doc => {
                if (doc.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.src = doc.data;
                    img.alt = doc.name;
                    img.style.maxWidth = '45%';
                    img.style.maxHeight = '80vh';
                    img.style.borderRadius = '10px';
                    documentContent.appendChild(img);
                } else if (doc.type === 'application/pdf') {
                    const iframe = document.createElement('iframe');
                    iframe.src = doc.data;
                    iframe.style.width = '90vw';
                    iframe.style.height = '80vh';
                    iframe.style.border = 'none';
                    iframe.style.borderRadius = '10px';
                    documentContent.appendChild(iframe);
                }
            });

            document.getElementById('documentModal').style.display = 'flex';
        }

        function closeDocumentViewer() {
            document.getElementById('documentModal').style.display = 'none';
        }

        function editStudent(index) {
            const student = students[index];
            
            document.getElementById('editIndex').value = index;
            document.getElementById('editName').value = student.name;
            document.getElementById('editPhone').value = student.phone;
            document.getElementById('editGuardianPhone').value = student.guardianPhone || '';
            document.getElementById('editGrade').value = student.grade;
            document.getElementById('editStatus').value = student.status;
            document.getElementById('editNotes').value = student.notes;
            
            document.getElementById('editModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
        }

        document.getElementById('editForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const index = parseInt(document.getElementById('editIndex').value);
            students[index].name = document.getElementById('editName').value;
            students[index].phone = document.getElementById('editPhone').value;
            students[index].guardianPhone = document.getElementById('editGuardianPhone').value;
            students[index].grade = parseFloat(document.getElementById('editGrade').value);
            students[index].status = document.getElementById('editStatus').value;
            students[index].notes = document.getElementById('editNotes').value;
            
            saveToSession();
            updateStudentsList();
            updateStats();
            closeEditModal();
            
            alert('تم تحديث بيانات الطالب بنجاح!');
        });

        function deleteStudent(index) {
            const student = students[index];
            if (confirm(`هل أنت متأكد من حذف الطالب "${student.name}"؟`)) {
                students.splice(index, 1);
                saveToSession();
                updateStudentsList();
                updateStats();
                alert('تم حذف الطالب بنجاح!');
            }
        }

        // Schools Management
        function updateSchoolsList() {
            const schoolsList = document.getElementById('schoolsList');
            schoolsList.innerHTML = '';
            
            // Get unique schools from students
            const uniqueSchools = [...new Set(students.map(s => s.middleSchool))];
            
            if (uniqueSchools.length === 0) {
                schoolsList.innerHTML = '<p style="text-align: center; color: #999; padding: 30px;">لا توجد مدارس بعد</p>';
                return;
            }
            
            // Count students per school
            const schoolCounts = {};
            students.forEach(s => {
                schoolCounts[s.middleSchool] = (schoolCounts[s.middleSchool] || 0) + 1;
            });
            
            uniqueSchools.sort().forEach(school => {
                const div = document.createElement('div');
                div.className = 'school-item';
                
                div.innerHTML = `
                    <div>
                        <strong>${school}</strong>
                        <span style="color: #666; margin-right: 10px;">(${schoolCounts[school]} طالب)</span>
                    </div>
                `;
                
                schoolsList.appendChild(div);
            });
        }

        // Communication Functions
        function sendWhatsAppAll() {
            const phones = students.map(s => s.phone).join(',');
            const message = encodeURIComponent('مرحباً، هذه رسالة من ثانوية السروات');
            window.open(`https://wa.me/?text=${message}`, '_blank');
        }

        function copyAllPhones() {
            const phones = students.map(s => s.phone).join('\n');
            navigator.clipboard.writeText(phones).then(() => {
                alert(`تم نسخ ${students.length} رقم إلى الحافظة!`);
            });
        }

        function copyAcceptedPhones() {
            const acceptedPhones = students.filter(s => s.status === 'accepted').map(s => s.phone).join('\n');
            if (acceptedPhones) {
                navigator.clipboard.writeText(acceptedPhones).then(() => {
                    const count = students.filter(s => s.status === 'accepted').length;
                    alert(`تم نسخ ${count} رقم للطلاب المقبولين!`);
                });
            } else {
                alert('لا يوجد طلاب مقبولين حالياً');
            }
        }

        function printList() {
            const printWindow = window.open('', '', 'height=600,width=800');
            printWindow.document.write('<html><head><title>قائمة الطلاب</title>');
            printWindow.document.write('<style>body{font-family:Arial;direction:rtl}table{width:100%;border-collapse:collapse}th,td{border:1px solid #ddd;padding:8px;text-align:center}th{background:#667eea;color:white}</style>');
            printWindow.document.write('</head><body>');
            printWindow.document.write('<h1 style="text-align:center">ثانوية السروات - قائمة الطلاب المسجلين</h1>');
            printWindow.document.write('<table><thead><tr><th>#</th><th>الاسم</th><th>الهوية</th><th>الجوال</th><th>المدرسة</th><th>الدرجة</th><th>الحالة</th></tr></thead><tbody>');
            
            const sortedStudents = [...students].sort((a, b) => b.grade - a.grade);
            sortedStudents.forEach((s, i) => {
                const statusText = {'pending': 'قيد المراجعة', 'accepted': 'مقبول', 'rejected': 'مرفوض'}[s.status];
                printWindow.document.write(`<tr><td>${i+1}</td><td>${s.name}</td><td>${s.id}</td><td>${s.phone}</td><td>${s.middleSchool}</td><td>${s.grade}</td><td>${statusText}</td></tr>`);
            });
            
            printWindow.document.write('</tbody></table></body></html>');
            printWindow.document.close();
            printWindow.print();
        }

        // Data Management
        function saveData() {
            if (students.length === 0) {
                alert('لا توجد بيانات للحفظ');
                return;
            }

            const dataStr = JSON.stringify({
                students: students,
                savedAt: new Date().toLocaleString('ar-SA'),
                version: '2.0'
            }, null, 2);

            const dataBlob = new Blob([dataStr], { type: 'application/json' });
            const url = URL.createObjectURL(dataBlob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `sarwat-backup-${Date.now()}.json`;
            link.click();
            URL.revokeObjectURL(url);

            alert('تم حفظ النسخة الاحتياطية بنجاح!');
        }

        function loadData(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = JSON.parse(e.target.result);
                    if (data.students && Array.isArray(data.students)) {
                        students = data.students;
                        saveToSession();
                        updateStudentsList();
                        updateStats();
                        alert(`تم تحميل ${students.length} طالب بنجاح!`);
                    } else {
                        alert('ملف غير صالح!');
                    }
                } catch(err) {
                    alert('خطأ في قراءة الملف!');
                }
            };
            reader.readAsText(file);
            
            event.target.value = '';
        }

        function exportToExcel() {
            let csv = 'رقم الهوية,الاسم,جوال الطالب,جوال ولي الأمر,المدرسة المتوسطة,الدرجة,الحالة,الملاحظات,تاريخ التسجيل\n';
            
            students.forEach(s => {
                const statusText = {'pending': 'قيد المراجعة', 'accepted': 'مقبول', 'rejected': 'مرفوض'}[s.status];
                csv += `${s.id},${s.name},${s.phone},${s.guardianPhone || ''},${s.middleSchool},${s.grade},${statusText},"${s.notes || ''}",${s.timestamp}\n`;
            });

            // Add BOM for Arabic support
            const BOM = '\uFEFF';
            const blob = new Blob([BOM + csv], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `sarwat-students-${Date.now()}.csv`;
            link.click();
            
            alert('تم تصدير البيانات إلى Excel بنجاح!');
        }

        function exportToCSV() {
            exportToExcel(); // Same as Excel export
        }

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = 'none';
            }
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', function() {
            // Page initialized
        });
    </script>
</body>
</html>
